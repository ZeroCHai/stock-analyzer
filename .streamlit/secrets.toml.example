# ── Streamlit Community Cloud Secrets Template ────────────────────────────────
# Copy the contents of this file into the Streamlit Cloud "Secrets" editor.
# Do NOT commit secrets.toml with real keys — only commit this example file.
#
# Path in Streamlit Cloud UI:
#   Your app → Settings → Secrets → paste below

# Provider: "ark" (Seed 2.0, default) or "gemini"
AI_PROVIDER = "ark"

# ── ByteDance Ark / Seed 2.0 (recommended) ────────────────────────────────────
ARK_API_KEY = "your-ark-api-key"
ARK_MODEL   = "ep-20250101-xxxxxx"   # your deployed endpoint ID

# ── Google Gemini (alternative) ───────────────────────────────────────────────
# AI_PROVIDER   = "gemini"
# GEMINI_API_KEY = "your-gemini-api-key"
# GEMINI_MODEL   = "gemini-2.0-flash"
