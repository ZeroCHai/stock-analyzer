# ── Provider selection ────────────────────────────────────────────────────────
# "gemini" (default) or "ark"
# AI_PROVIDER=gemini

# ── Mode 1: Gemini API key (simplest) ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ── Mode 2: Gemini Vertex AI OAuth (higher quota, no API key needed) ─────────
# Step 1: gcloud auth application-default login
#         OR export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Step 2: set the project below
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GEMINI_LOCATION=us-central1

# ── Mode 3: ByteDance Ark / Seed2.0 AK/SK ────────────────────────────────────
# AI_PROVIDER=ark
# VOLC_ACCESSKEY=your_volc_access_key
# VOLC_SECRETKEY=your_volc_secret_key
# ARK_MODEL=ep-20250101-xxxxxx   # deployed endpoint ID
