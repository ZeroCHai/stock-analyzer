# ── Provider selection ────────────────────────────────────────────────────────
# "ark" (default) or "gemini"
# AI_PROVIDER=ark

# ════════════════════════════════════════════════════════════════════════════
# MODE 1 — ByteDance Ark / Seed2.0  (default provider)
# ════════════════════════════════════════════════════════════════════════════

# Option A: API Key (simpler)
# Get key from: https://console.volcengine.com/ark
ARK_API_KEY=your_ark_api_key_here
ARK_MODEL=ep-20250101-xxxxxx          # deployed endpoint ID (e.g. Seed2.0 / Doubao)

# Option B: AK/SK (higher quota, uses HMAC signing)
# VOLC_ACCESSKEY=your_volc_access_key
# VOLC_SECRETKEY=your_volc_secret_key
# ARK_MODEL=ep-20250101-xxxxxx

# ════════════════════════════════════════════════════════════════════════════
# MODE 2 — Google Gemini  (set AI_PROVIDER=gemini to use)
# ════════════════════════════════════════════════════════════════════════════

# Option A: API Key
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Option B: Vertex AI OAuth (higher quota)
# Step 1: gcloud auth application-default login
#         OR: export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Step 2: set project below
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GEMINI_LOCATION=us-central1
